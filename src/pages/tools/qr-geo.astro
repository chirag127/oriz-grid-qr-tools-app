---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="QR geo / event — Oriz QR & Barcode Tools" description="Generate a geo: location QR or an iCalendar event QR. Scan to open in maps or add to calendar. Runs entirely in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">QR geo / event</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="lede">Two modes. <strong>geo</strong> opens the location in the phone's map app. <strong>event</strong> emits a minimal iCalendar VEVENT that most calendar apps recognise on scan.</p>

    <div class="layout">
      <div class="controls">
        <label class="field"><span class="field-label">Mode</span>
          <select id="mode" class="sel">
            <option value="geo" selected>Geo location</option>
            <option value="event">Calendar event</option>
          </select>
        </label>

        <div id="geo-fields">
          <label class="field"><span class="field-label">Latitude</span><input id="lat" class="io" placeholder="40.7128" /></label>
          <label class="field"><span class="field-label">Longitude</span><input id="lng" class="io" placeholder="-74.0060" /></label>
          <button id="use-loc" type="button" class="btn-secondary small">Use my location</button>
        </div>

        <div id="event-fields" hidden>
          <label class="field"><span class="field-label">Title</span><input id="ev-title" class="io" /></label>
          <label class="field"><span class="field-label">Location</span><input id="ev-loc" class="io" /></label>
          <label class="field"><span class="field-label">Start</span><input id="ev-start" class="io" type="datetime-local" /></label>
          <label class="field"><span class="field-label">End</span><input id="ev-end" class="io" type="datetime-local" /></label>
          <label class="field"><span class="field-label">Description</span><textarea id="ev-desc" class="io" rows="2"></textarea></label>
        </div>

        <div class="btn-row">
          <button id="btn-png" class="btn-primary" disabled>Download PNG</button>
          <button id="btn-svg" class="btn-secondary" disabled>Download SVG</button>
        </div>
      </div>
      <div class="preview-wrap">
        <canvas id="qr-canvas" width="256" height="256"></canvas>
        <p id="qr-placeholder" class="placeholder-hint mono">fill the form to generate</p>
        <p id="qr-error" class="error-hint mono" hidden></p>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
let QRCode: any = null
async function loadQRCode() {
  if (QRCode) return QRCode
  return new Promise<any>((resolve, reject) => {
    if ((window as any).QRCode) { QRCode = (window as any).QRCode; resolve(QRCode); return }
    const s = document.createElement('script')
    s.src = 'https://unpkg.com/qrcode@1.5.4/build/qrcode.min.js'
    s.onload = () => { QRCode = (window as any).QRCode; resolve(QRCode) }
    s.onerror = reject
    document.head.appendChild(s)
  })
}

const $ = (id: string) => document.getElementById(id) as any
const mode = $('mode') as HTMLSelectElement
const geoFields = $('geo-fields')
const evFields = $('event-fields')
const canvas = $('qr-canvas') as HTMLCanvasElement
const placeholder = $('qr-placeholder')
const errorEl = $('qr-error')
const btnPng = $('btn-png')
const btnSvg = $('btn-svg')
let lastSvg = ''
let timer: ReturnType<typeof setTimeout>

function fmtICalDT(s: string) {
  if (!s) return ''
  const d = new Date(s)
  if (isNaN(d.getTime())) return ''
  const z = (n: number) => String(n).padStart(2, '0')
  return `${d.getUTCFullYear()}${z(d.getUTCMonth() + 1)}${z(d.getUTCDate())}T${z(d.getUTCHours())}${z(d.getUTCMinutes())}${z(d.getUTCSeconds())}Z`
}
const escIcal = (s: string) => s.replace(/([\\;,])/g, '\\$1').replace(/\n/g, '\\n')

function payload() {
  if (mode.value === 'geo') {
    const lat = parseFloat($('lat').value), lng = parseFloat($('lng').value)
    if (isNaN(lat) || isNaN(lng)) return ''
    return `geo:${lat},${lng}`
  }
  const t = $('ev-title').value.trim()
  const start = fmtICalDT($('ev-start').value)
  const end = fmtICalDT($('ev-end').value)
  if (!t || !start) return ''
  const uid = `${Date.now()}-${Math.random().toString(36).slice(2)}@oriz`
  const lines = ['BEGIN:VCALENDAR', 'VERSION:2.0', 'PRODID:-//Oriz//QR//EN', 'BEGIN:VEVENT', `UID:${uid}`, `DTSTAMP:${fmtICalDT(new Date().toISOString())}`, `DTSTART:${start}`]
  if (end) lines.push(`DTEND:${end}`)
  lines.push(`SUMMARY:${escIcal(t)}`)
  if ($('ev-loc').value) lines.push(`LOCATION:${escIcal($('ev-loc').value)}`)
  if ($('ev-desc').value) lines.push(`DESCRIPTION:${escIcal($('ev-desc').value)}`)
  lines.push('END:VEVENT', 'END:VCALENDAR')
  return lines.join('\r\n')
}

async function gen() {
  const data = payload()
  if (!data) {
    placeholder.hidden = false; errorEl.hidden = true
    canvas.style.display = 'none'
    btnPng.disabled = btnSvg.disabled = true
    return
  }
  try {
    const QR = await loadQRCode()
    await QR.toCanvas(canvas, data, { width: 256, errorCorrectionLevel: 'M', margin: 2 })
    lastSvg = await QR.toString(data, { type: 'svg', width: 256, errorCorrectionLevel: 'M', margin: 2 })
    placeholder.hidden = true; errorEl.hidden = true
    canvas.style.display = 'block'
    btnPng.disabled = btnSvg.disabled = false
  } catch (e: any) {
    errorEl.textContent = `Error: ${e?.message ?? String(e)}`; errorEl.hidden = false
    placeholder.hidden = true; canvas.style.display = 'none'
  }
}

const schedule = () => { clearTimeout(timer); timer = setTimeout(gen, 200) }
mode.addEventListener('change', () => {
  const isGeo = mode.value === 'geo'
  geoFields.hidden = !isGeo; evFields.hidden = isGeo
  gen()
})
document.querySelectorAll<HTMLElement>('.controls input, .controls textarea').forEach(el => el.addEventListener('input', schedule))

$('use-loc').addEventListener('click', () => {
  if (!navigator.geolocation) { errorEl.textContent = 'Geolocation not supported'; errorEl.hidden = false; return }
  navigator.geolocation.getCurrentPosition(
    p => { $('lat').value = p.coords.latitude.toFixed(6); $('lng').value = p.coords.longitude.toFixed(6); gen() },
    err => { errorEl.textContent = `Location error: ${err.message}`; errorEl.hidden = false }
  )
})

btnPng.addEventListener('click', () => {
  const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = 'qr.png'; a.click()
})
btnSvg.addEventListener('click', () => {
  const blob = new Blob([lastSvg], { type: 'image/svg+xml' })
  const url = URL.createObjectURL(blob)
  const a = document.createElement('a'); a.href = url; a.download = 'qr.svg'; a.click()
  setTimeout(() => URL.revokeObjectURL(url), 1000)
})
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 1rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 2rem; }
  .layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 700px) { .layout { grid-template-columns: 1fr 1fr; align-items: start; } }
  .controls { display: flex; flex-direction: column; gap: 1rem; }
  #geo-fields, #event-fields { display: flex; flex-direction: column; gap: 0.85rem; }
  .field { display: flex; flex-direction: column; gap: 0.3rem; }
  .field-label { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; font-family: var(--font-mono); }
  .io, .sel { width: 100%; padding: 0.6rem 0.85rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; }
  .io:focus, .sel:focus { outline: 2px solid var(--accent); outline-offset: -2px; }
  textarea.io { resize: vertical; }
  .btn-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn-primary, .btn-secondary { padding: 0.5rem 1.25rem; font-family: var(--font-mono); font-size: 0.875rem; border: 1px solid var(--rule); cursor: pointer; }
  .btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .btn-secondary { background: var(--paper-2); color: var(--ink); }
  .btn-secondary.small { padding: 0.35rem 0.85rem; font-size: 0.75rem; align-self: flex-start; margin-top: 0.25rem; }
  .btn-primary:disabled, .btn-secondary:disabled { opacity: 0.4; cursor: not-allowed; }
  .preview-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 260px; border: 1px solid var(--rule); background: var(--paper-2); padding: 1.5rem; }
  #qr-canvas { display: none; max-width: 100%; image-rendering: pixelated; }
  .placeholder-hint { font-size: 12px; color: var(--muted); letter-spacing: 0.08em; margin: 0; text-align: center; }
  .error-hint { font-size: 12px; color: #dc2626; margin: 0; text-align: center; }
</style>
