---
import '~/styles/global.css'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz QR & Barcode Tools — Pixels carry payload. Generated, scanned, and saved in your browser.', description = 'QR + barcode suite: generate, style, scan, bulk-batch. vCard, WiFi, geo, event. Code-128, EAN-13, UPC, ITF, MSI.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://qr.oriz.in').toString()
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">QR Tools</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href="https://oriz.in/pricing?from=oriz-grid-qr-tools-app">pricing</a>
        <a href="https://account.oriz.in/sign-in?return=https://qr.oriz.in/">sign in</a>
      </nav>
    </header>
    <div class="oriz-shell">
      <FamilySidebar slug="oriz-grid-qr-tools-app" title="QR Tools">
        <a slot="tools" href="/tools/qr-text/">QR generator (text / URL)</a>
        <a slot="tools" href="/tools/qr-scan/">QR decoder (camera / file)</a>
        <a slot="tools" href="/tools/barcode/">Barcode generator</a>
        <a slot="tools" href="/tools/url-preview/">URL shortener preview</a>
        <a slot="tools" href="/tools/qr-vcard/">QR vCard</a>
        <a slot="tools" href="/tools/qr-wifi/">QR WiFi credentials</a>
        <a slot="tools" href="/tools/qr-email/">QR email / SMS / phone</a>
        <a slot="tools" href="/tools/qr-geo/">QR geo / event</a>
        <a slot="tools" href="/tools/qr-styled/">Styled QR with logo</a>
        <a slot="tools" href="/tools/qr-bulk/">Bulk CSV → ZIP of QR PNGs</a>
      </FamilySidebar>
      <main id="main" class="oriz-main"><slot /></main>
    </div>
    <footer class="site">
      <span>Oriz QR & Barcode Tools · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
    <style>
      nav a { min-height: 32px; padding: 6px 0; display: inline-flex; align-items: center; }
    </style>
  </body>
</html>
